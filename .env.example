# Copy to .env for local development. All values validated at boot via src/lib/env.ts.

# Postgres connection string. Matches docker-compose.yml defaults.
DATABASE_URL=postgres://app:app@localhost:5432/seat_reservation

# Session cookie config
SESSION_COOKIE_NAME=seat_session
SESSION_TTL_DAYS=90

# How long a hold lasts before the seat is released. Configurable for demo/testing.
HOLD_TTL_MINUTES=10

# How long a payment may sit in 'paying' before the sweeper flags it for operator review.
PAYING_TIMEOUT_MINUTES=30

# HMAC secret used by the mock payment provider to sign webhook payloads. In production
# this would be the provider's signing secret (e.g., STRIPE_WEBHOOK_SECRET). Replace
# with a long random string for any deployment. The dev value is fine for local only.
MOCK_PAYMENT_WEBHOOK_SECRET=dev-only-mock-webhook-secret-do-not-use-in-prod

# Where the mock provider's UI lives. Same origin as the app in dev.
MOCK_PAYMENT_BASE_URL=http://localhost:3000

# Gate for the in-repo mock payment provider routes. Set to "false" in any
# real deploy (and use a real provider behind the PaymentProvider interface).
MOCK_PAYMENT_ENABLED=true

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Standard
NODE_ENV=development
